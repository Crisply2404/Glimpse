# Tavily（全网搜索）
TAVILY_API_KEY=

# OpenAI（提炼候选 + 打分解释）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 可选：代理/自定义网关（默认不用）
# 提示：本项目会自动拼接 `/v1/chat/completions`，所以这里一般填“根地址”（不要再手动加 /v1）
# 但如果你的中转服务本身就要求以 `/v1` 结尾，本项目也兼容（不会重复拼接）。
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_BASE_URL=https://www.right.codes/codex
# OPENAI_BASE_URL=https://www.right.codes/codex/v1
